# ============================================
# Kattlog — Variables de entorno
# ============================================
# Copia este archivo como .env.local y rellena los valores reales:
#   cp .env.example .env.local

# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Google Gemini (AI para scraping y análisis de productos)
GEMINI_API_KEY=your_gemini_api_key

# OpenAI (AI para catálogos y moodboards)
OPENAI_API_KEY=your_openai_api_key

# Firecrawl (scraping alternativo — opcional)
FIRECRAWL_API_KEY=your_firecrawl_api_key
